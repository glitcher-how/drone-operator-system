# ================================================================
# Kafka брокер (официальный SDK курса: sbd-drones-economics)
# Запустить локально: cd sbd-drones-economics/docker && docker-compose --profile kafka up -d
# ================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Аутентификация Kafka (SASL PLAIN, обязательно!)
# Дефолтные значения из docker/example.env
BROKER_USER=admin
BROKER_PASSWORD=admin_secret_123

# ================================================================
# Топик событий М2
# ================================================================
KAFKA_TOPIC=drone_events
ENABLE_KAFKA_EVENTS=true

# ================================================================
# Aggregator (команда Agregator-main)
# Топик входящих заказов
AGGREGATOR_REQUESTS_TOPIC=v1.aggregator_insurer.local.operator.requests
# Топик ответов М2 → Aggregator
AGGREGATOR_RESPONSES_TOPIC=v1.aggregator_insurer.local.operator.responses

# ================================================================
# DronePort (команда DronePortGCS-main)
# Топик реестра дронов
DRONEPORT_REGISTRY_TOPIC=v1.drone_port.1.registry
# Топик для ответов DronePort → М2 (автоматически создаётся)
M2_REPLY_TOPIC=v1.replies.m2_operator.droneport
# Интервал синхронизации дронов из DronePort (секунды)
DRONEPORT_SYNC_INTERVAL=60

# ================================================================
# ОрВД (команда OpBD-main)
# ================================================================
ORVD_TOPIC=v1.ORVD.ORVD001.main

# ================================================================
# Страховая (команда Insurer-main)
# ================================================================
INSURER_REQUESTS_TOPIC=v1.Insurer.1.insurer-service.requests
INSURER_RESPONSES_TOPIC=v1.Insurer.1.insurer-service.responses

# ================================================================
# НУС / GCS (команда DronePortGCS-main)
# ================================================================
GCS_TOPIC=v1.gcs.1.orchestrator

# ================================================================
# Reply-топик для синхронных запросов М2
# ================================================================
M2_REPLY_BASE=v1.replies.m2_operator

# ================================================================
# Идентификация М2
# ================================================================
M2_OPERATOR_ID=m2_operator
M2_OPERATOR_NAME=M2 Drone Operator
